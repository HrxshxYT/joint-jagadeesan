DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# External PostgreSQL. The bot never provisions its own database — point this at a
# Postgres reachable from wherever the bot runs, and `prisma migrate deploy` will
# create the tables on first boot.
# Shape: postgresql://user:pass@host:5432/dbname  (percent-encode specials in the password)
DATABASE_URL=
NODE_ENV=development
DEV_GUILD_ID=
BOT_SHARD_COUNT=auto
LOG_LEVEL=info
# Port for the keep-alive HTTP endpoint that UptimeRobot pings. Most free hosts
# (Replit, etc.) inject their own PORT — leave unset there. Defaults to 3000.
PORT=3000
# Optional overrides for the links shown in the "thanks for adding" onboarding
# message. Leave unset to use the built-in defaults in src/lib/constants.js.
SUPPORT_SERVER_URL=
OWNER_SERVER_URL=
UPTIME_URL=
