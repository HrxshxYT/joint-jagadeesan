DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# External PostgreSQL. The bot never provisions its own database — point this at a
# Postgres reachable from wherever the bot runs, and `prisma migrate deploy` will
# create the tables on first boot.
# Shape: postgresql://user:pass@host:5432/dbname  (percent-encode specials in the password)
DATABASE_URL=
NODE_ENV=development
DEV_GUILD_ID=
BOT_SHARD_COUNT=auto
LOG_LEVEL=info

# Optional Lavalink node for the music feature. Leave LAVALINK_HOST blank to keep
# music disabled (the bot still runs; music commands reply "not configured").
# For Spotify/Apple links the node needs the LavaSrc plugin.
LAVALINK_HOST=
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
LAVALINK_SECURE=false
