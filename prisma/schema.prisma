generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id            String          @id
  createdAt     DateTime        @default(now())
  modLogEnabled Boolean         @default(false)
  dmOnAction    Boolean         @default(true)
  muteRoleId    String?
  antinuke      AntinukeConfig?
  automod       AutomodConfig?
  logging       LoggingConfig?
  welcome       WelcomeConfig?
  audit         AuditConfig?
  whitelist     Whitelist[]
  modRoles      ModRole[]
  cases         Case[]
  autoRoles     AutoRole[]
  reactionRoles ReactionRole[]
  leveling      LevelingConfig?
  watchVc       WatchVcConfig?
  ticketConfig  TicketConfig?
  ticketPanels  TicketPanel[]
  tickets       Ticket[]
  ticketCounter TicketCounter?
  dashboards    Dashboard[]
}

// A live /dashboard message that keeps refreshing until deleted. Persisted so
// the refresh loop can be restored after a bot restart.
model Dashboard {
  id        String   @id // Discord message id
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  createdAt DateTime @default(now())

  @@index([guildId])
}

model AntinukeConfig {
  guildId          String  @id
  guild            Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled          Boolean @default(false)
  punishment       String  @default("ban") // ban | kick | strip | quarantine | removeperms
  autoRevert       Boolean @default(true)
  alertChannelId   String?
  quarantineRoleId String?
  antiRaidEnabled  Boolean @default(false)
  raidJoinCount    Int     @default(10)
  raidWindowSec    Int     @default(10)
  panicMode        Boolean @default(false)
  thresholds       Json    @default("{}") // { actionKey: { limit, windowSec, enabled } }
  // When on, whitelisted users are still tripped if they exceed a per-action
  // limit. whitelistLimits: { actionKey: { enabled, limit, windowSec } }.
  whitelistLimitEnabled Boolean @default(false)
  whitelistLimits       Json    @default("{}")
}

model Whitelist {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  targetId  String
  type      String // user | role
  addedById String
  createdAt DateTime @default(now())

  @@unique([guildId, targetId])
}

model LoggingConfig {
  guildId         String  @id
  guild           Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  memberJoinLeave String?
  messageEdit     String?
  messageDelete   String?
  modActions      String?
  roleChanges     String?
  channelChanges  String?
  voice           String?
  serverChanges   String?
  disabled        Json    @default("[]") // list of category keys turned off
}

model ModRole {
  id      String @id @default(cuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  roleId  String

  @@unique([guildId, roleId])
}

model Case {
  id          String    @id @default(cuid())
  guildId     String
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  caseNumber  Int
  type        String // ban|tempban|softban|kick|timeout|mute|warn|unban|unmute
  targetId    String
  moderatorId String
  reason      String    @default("No reason provided")
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  active      Boolean   @default(true)

  @@unique([guildId, caseNumber])
  @@index([guildId, targetId])
}

model MemberInvite {
  id        String   @id @default(cuid())
  guildId   String
  memberId  String
  inviterId String?
  code      String?
  joinedAt  DateTime @default(now())
  left      Boolean  @default(false)

  @@unique([guildId, memberId])
  @@index([guildId, inviterId])
}

model InviteBonus {
  guildId String
  userId  String
  amount  Int    @default(0)

  @@id([guildId, userId])
}

model AutomodConfig {
  guildId         String  @id
  guild           Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled         Boolean @default(false)
  antiSpam        Boolean @default(true)
  spamCount       Int     @default(5)
  spamWindowSec   Int     @default(5)
  antiMentionSpam Boolean @default(true)
  mentionLimit    Int     @default(5)
  filterInvites   Boolean @default(true)
  filterLinks     Boolean @default(false)
  antiCaps        Boolean @default(false)
  capsPercent     Int     @default(70)
  capsMinLength   Int     @default(10)
  antiEmojiSpam   Boolean @default(false)
  emojiLimit      Int     @default(8)
  action          String  @default("delete") // delete | warn | timeout
  timeoutSeconds  Int     @default(300)
  exemptRoles     Json    @default("[]")
  exemptChannels  Json    @default("[]")

  // Native Discord AutoMod: rules provisioned via the AutoModeration API
  // (earns the "Uses AutoMod" badge and blocks at Discord's edge). Punishments
  // are configurable per the block/alert/timeout actions below.
  nativeEnabled        Boolean @default(false)
  nativeInvites        Boolean @default(true)
  nativeScamLinks      Boolean @default(true)
  nativeGrabbers       Boolean @default(true)
  nativeNitroScams     Boolean @default(true)
  nativeCryptoScams    Boolean @default(true)
  nativeAdSpam         Boolean @default(true)
  nativeMentions       Boolean @default(true)
  nativeSpam           Boolean @default(true)
  nativePresets        Boolean @default(true)
  nativeAlert          Boolean @default(true)
  nativeAlertChannelId String?
  nativeTimeout        Boolean @default(true)
  nativeTimeoutSeconds Int     @default(300)
}

model WelcomeConfig {
  guildId          String  @id
  guild            Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  welcomeEnabled   Boolean @default(false)
  welcomeChannelId String?
  welcomeMessage   String  @default("Welcome {mention} to **{server}**! You are member #{memberCount}.")
  goodbyeEnabled   Boolean @default(false)
  goodbyeChannelId String?
  goodbyeMessage   String  @default("**{user}** has left the server.")
}

model WatchVcConfig {
  guildId   String   @id
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String?
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AutoRole {
  id      String @id @default(cuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  roleId  String

  @@unique([guildId, roleId])
}

model AuditConfig {
  guildId   String  @id
  guild     Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled   Boolean @default(false)
  channelId String?
  events    Json    @default("{}") // { categoryKey: bool }; missing key = enabled
}

model ReactionRole {
  id        String @id @default(cuid())
  guildId   String
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  messageId String
  emoji     String
  roleId    String

  @@unique([guildId, messageId, emoji])
  @@index([guildId, messageId])
}

// Global, cross-shard singleton counters (e.g. cumulative anti-nuke triggers).
model BotStat {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model LevelingConfig {
  guildId         String  @id
  guild           Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled         Boolean @default(false)
  xpMin           Int     @default(15)
  xpMax           Int     @default(25)
  cooldownSec     Int     @default(60)
  announce        Boolean @default(true)
  ignoredChannels Json    @default("[]")
  ignoredRoles    Json    @default("[]")
}

model MemberLevel {
  guildId String
  userId  String
  xp      Int    @default(0)

  @@id([guildId, userId])
  @@index([guildId, xp])
}

model LevelReward {
  guildId String
  level   Int
  roleId  String

  @@id([guildId, level])
}

model TicketConfig {
  guildId             String  @id
  guild               Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled             Boolean @default(true)
  transcriptChannelId String?
  dmTranscript        Boolean @default(false)
  logChannelId        String?
  maxOpenPerUser      Int     @default(1)
}

model TicketPanel {
  id          String           @id @default(cuid())
  guildId     String
  guild       Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name        String
  title       String           @default("Open a Ticket")
  description String           @default("Select a category below to open a ticket.")
  channelId   String?
  messageId   String?
  createdAt   DateTime         @default(now())
  categories  TicketCategory[]

  @@index([guildId])
}

model TicketCategory {
  id                String      @id @default(cuid())
  panelId           String
  panel             TicketPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  label             String
  emoji             String?
  description       String?
  discordCategoryId String?
  staffRoleIds      Json        @default("[]")
  namePrefix        String      @default("ticket")
  welcomeMessage    String      @default("Thanks {mention}, staff will be with you shortly.")
  reasonPrompt      String?
  position          Int         @default(0)

  @@index([panelId])
}

model Ticket {
  id          String    @id @default(cuid())
  guildId     String
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  number      Int
  panelId     String?
  categoryId  String?
  channelId   String    @unique
  openerId    String
  claimedById String?
  status      String    @default("open") // open | archived | closed
  reason      String?
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  @@unique([guildId, number])
  @@index([guildId, status])
  @@index([openerId, status])
}

model TicketCounter {
  guildId String @id
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  next    Int    @default(1)
}
